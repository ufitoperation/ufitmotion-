# Required
UFIT_SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
APP_ENV=development

# Email delivery via Resend (required for password resets and user invites)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Ufit Motion <noreply@yourdomain.com>

# Error tracking via Sentry (optional but strongly recommended for production)
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# HubSpot integration
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_WEBHOOK_SECRET=your-hubspot-webhook-secret

# App URL (used in email links)
UFIT_APP_BASE_URL=http://localhost:5000

# Render deploy root (production only — set to /opt/render/project/src on Render)
UFIT_APP_ROOT=/opt/render/project/src

# Redis for distributed rate limiting (optional — only needed if scaling to 2+ gunicorn workers)
REDIS_URL=redis://localhost:6379/0

# Dev seed password (development only — never set in production)
UFIT_SEED_PASSWORD=changeme-dev-only
